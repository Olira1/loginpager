{
  "info": {
    "_postman_id": "f1e24530-4d93-4ac5-90f2-d593038e0e42",
    "name": "School Portal - Admin Endpoints (Step 3)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Manual/Postman test collection for Backend Admin Endpoints including School Management, School Head Management, Promotion Criteria, and Statistics."
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (Admin) - Set adminToken",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.access_token) {",
                  "  pm.collectionVariables.set('adminToken', json.data.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{adminUsername}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            },
            "description": "Run this first. It stores access token into collection variable `adminToken`."
          }
        }
      ]
    },
