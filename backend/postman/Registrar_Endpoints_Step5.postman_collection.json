  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('timestamp')) {",
          "  pm.collectionVariables.set('timestamp', Date.now().toString());",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "registrarUsername",
      "value": "almaz.tadesse@school.edu.et"
    },
    {
      "key": "registrarPassword",
      "value": "SecurePass@123"
    },
    {
      "key": "registrarToken",
      "value": ""
    },
    {
      "key": "studentId",
      "value": "1"
    },
    {
      "key": "teacherId",
      "value": "1"
    },
    {
      "key": "parentId",
      "value": "1"
    },
    {
      "key": "userIdToReset",
      "value": "1"
